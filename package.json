{
  "name": "intrack",
  "private": true,
  "version": "0.6.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:rate-limit": "deno test --lock=deno.lock supabase/tests/rate-limit-test.ts supabase/tests/rate-limit-handler-test.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test": "npm run test:rate-limit && npm run test:unit",
    "test:cors-smoke": "deno test --allow-net --allow-env supabase/tests/cors-smoke-test.ts",
    "test:e2e": "playwright test",
    "sb:local:generate:schema": "npx supabase gen types typescript --local > src/schema.ts",
    "sb:local:start": "npx supabase start",
    "sb:local:db:seed:users": "node supabase/seed-users.js",
    "sb:local:stop": "npx supabase stop",
    "sb:local:status": "npx supabase status",
    "sb:local:db:recreate": "npx supabase db reset",
    "sb:local:functions:deploy": "npx supabase functions serve rate-limit &",
    "sb:local:db:pull": "npx supabase db pull",
    "sb:local:db:diff": "npx supabase db diff",
    "sb:local:db:migration:new": "npx supabase migration new",
    "generate:dummy:consultations": "tsx scripts/generate_dummy_consultations.ts"
  },
  "dependencies": {
